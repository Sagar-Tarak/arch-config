# Force LF line endings for all text files — prevents CRLF on Windows checkouts.
* text=auto eol=lf

# Shell scripts must always be LF; they will fail with CRLF shebangs on Linux.
*.sh text eol=lf

# Config and template files deployed to ~/.config must also be LF.
*.conf  text eol=lf
*.toml  text eol=lf
*.css   text eol=lf
*.rasi  text eol=lf
*.fish  text eol=lf
*.lua   text eol=lf
*.txt   text eol=lf
*.md    text eol=lf

# Binary assets — no line-ending conversion.
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
